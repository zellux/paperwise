---
import config from 'virtual:starlight/user-config';

import Search from 'virtual:starlight/components/Search';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';

const shouldRenderSearch =
	config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';

const pathname = Astro.url.pathname.replace(/\/+$/, '') || '/docs';
const navItems = [
	{ label: 'Home', href: '/', activeWhen: () => false },
	{
		label: 'Docs',
		href: '/docs/',
		activeWhen: () => pathname === '/docs' || pathname.startsWith('/docs/'),
	},
];
---

<div class="docs-marketing-header">
	<a class="docs-brand" href="/" aria-label="Paperwise home">
		<img
			class="docs-brand__mark"
			src="/docs/paperwise-icon.png"
			alt=""
			aria-hidden="true"
			width="32"
			height="32"
		/>
		<span class="docs-brand__name">Paperwise</span>
	</a>

	<nav class="docs-marketing-nav" aria-label="Main">
		{
			navItems.map((item) => (
				<a
					class:list={['docs-nav-link', { 'docs-nav-link--active': item.activeWhen() }]}
					href={item.href}
				>
					{item.label}
				</a>
			))
		}
	</nav>

	<div class="docs-marketing-header__actions">
		{shouldRenderSearch && <div class="docs-search"><Search /></div>}
		<a
			class="docs-github-link"
			href="https://github.com/zellux/paperwise"
			target="_blank"
			rel="noopener noreferrer"
		>
			<svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor">
				<path
					d="M12 .3a12 12 0 0 0-3.8 23.38c.6.12.83-.26.83-.57L9 21.07c-3.34.72-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.08-.74.09-.73.09-.73 1.2.09 1.83 1.24 1.83 1.24 1.08 1.83 2.81 1.3 3.5 1 .1-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.14-.3-.54-1.52.1-3.18 0 0 1-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.28-1.55 3.29-1.23 3.29-1.23.64 1.66.24 2.88.12 3.18a4.65 4.65 0 0 1 1.23 3.22c0 4.61-2.8 5.63-5.48 5.92.42.36.81 1.1.81 2.22l-.01 3.29c0 .31.2.69.82.57A12 12 0 0 0 12 .3Z"
				/>
			</svg>
			<span>GitHub</span>
		</a>
		<div class="docs-theme-select">
			<ThemeSelect />
		</div>
	</div>
</div>

<style>
	@layer starlight.core {
		:global(:root) {
			--sl-nav-height: 4.5rem;
		}

		:global(.page > header.header) {
			border-bottom: 1px solid rgba(149, 168, 208, 0.24);
			background: rgba(247, 249, 253, 0.9);
			backdrop-filter: blur(18px);
		}

		.docs-marketing-header {
			display: grid;
			grid-template-columns: auto minmax(0, 1fr) auto;
			align-items: center;
			gap: 1.125rem;
			height: 100%;
		}

		.docs-marketing-header__actions {
			display: flex;
			align-items: center;
			gap: 0.75rem;
			min-width: 0;
		}

		.docs-brand {
			display: inline-flex;
			align-items: center;
			gap: 0.625rem;
			color: var(--sl-color-text);
			text-decoration: none;
			flex: 0 0 auto;
		}

		.docs-brand__mark {
			display: block;
			width: 2rem;
			height: 2rem;
			border-radius: 0.625rem;
		}

		.docs-brand__name {
			font-family: "Manrope", "Instrument Sans", system-ui, sans-serif;
			font-size: 1rem;
			font-weight: 800;
			letter-spacing: -0.03em;
		}

		.docs-marketing-nav {
			display: flex;
			align-items: center;
			gap: 0.5rem;
			min-width: 0;
			flex-wrap: wrap;
			justify-content: center;
		}

		.docs-nav-link,
		.docs-github-link :global(span) {
			font-size: 0.95rem;
			font-weight: 600;
		}

		.docs-nav-link,
		.docs-github-link {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			min-height: 2.625rem;
			padding: 0 0.875rem;
			border-radius: 999px;
			border: 1px solid transparent;
			color: var(--sl-color-gray-2);
			text-decoration: none;
			transition:
				background-color 0.18s ease,
				border-color 0.18s ease,
				transform 0.18s ease,
				color 0.18s ease;
		}

		.docs-nav-link:hover,
		.docs-github-link:hover {
			background: rgba(255, 255, 255, 0.84);
			transform: translateY(-1px);
		}

		.docs-nav-link--active {
			background: rgba(28, 121, 249, 0.1);
			border-color: rgba(28, 121, 249, 0.16);
			color: #175fc3;
		}

		.docs-github-link {
			gap: 0.5rem;
			border-color: rgba(149, 168, 208, 0.24);
			background: rgba(255, 255, 255, 0.76);
		}

		.docs-github-link svg {
			width: 1rem;
			height: 1rem;
			flex: 0 0 auto;
		}

		.docs-search {
			display: flex;
			align-items: center;
		}

		.docs-search :global(button[data-open-modal]) {
			min-height: 2.625rem;
			padding: 0 0.875rem;
			border-radius: 999px;
			border: 1px solid rgba(149, 168, 208, 0.24);
			background: rgba(255, 255, 255, 0.76);
		}

		.docs-search :global(button[data-open-modal]:hover) {
			background: rgba(255, 255, 255, 0.92);
		}

		.docs-theme-select :global(label) {
			min-height: 2.625rem;
			padding-inline: 0.75rem;
			border-radius: 999px;
			border: 1px solid rgba(149, 168, 208, 0.24);
			background: rgba(255, 255, 255, 0.76);
		}

		@media (max-width: 63.99rem) {
			.docs-marketing-header {
				grid-template-columns: auto minmax(0, 1fr) auto;
			}

			.docs-marketing-nav,
			.docs-theme-select {
				display: none;
			}
		}

		@media (max-width: 37.5rem) {
			:global(:root) {
				--sl-nav-height: 4rem;
			}

			.docs-github-link span,
			.docs-search :global(span[aria-hidden='true']),
			.docs-search :global(kbd) {
				display: none;
			}

			.docs-github-link,
			.docs-search :global(button[data-open-modal]) {
				padding-inline: 0.75rem;
			}
		}
	}
</style>
