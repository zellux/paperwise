PAPERWISE_ENV=local
PAPERWISE_LOG_LEVEL=INFO
PAPERWISE_API_HOST=0.0.0.0
PAPERWISE_API_PORT=8000
PAPERWISE_REDIS_URL=redis://localhost:6379/0
PAPERWISE_REPOSITORY_BACKEND=memory
PAPERWISE_POSTGRES_URL=postgresql+psycopg://paperwise:paperwise@localhost:5432/paperwise
PAPERWISE_OBJECT_STORE_ROOT=local/object-store
PAPERWISE_AUTH_SECRET=paperwise-dev-secret-change-me
PAPERWISE_SESSION_TTL_SECONDS=43200
